APP_NAME=social-notif
APP_ENV=local
APP_SHUTDOWN_TIMEOUT=15s

HTTP_PORT=8080
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_REQUEST_TIMEOUT=10s
HTTP_TRUSTED_PROXIES=

DATABASE_URL=postgres://postgres:postgres@localhost:5432/social_notif?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=10m
DB_CONNECT_TIMEOUT=5s
DB_CONNECT_MAX_RETRIES=5
DB_CONNECT_RETRY_BACKOFF=2s
DB_HEALTH_CHECK_TIMEOUT=2s
DB_SLOW_QUERY_THRESHOLD=500ms

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

QUEUE_CONCURRENCY=10
QUEUE_DEFAULT_PRIORITY=1

API_KEY=change-me
RATE_LIMIT_PER_MIN=120
MAX_REQUEST_BYTES=1048576

LOG_LEVEL=info

SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_APP_URL=http://localhost:8080

WHATSAPP_API_VERSION=v20.0
WHATSAPP_BASE_URL=https://graph.facebook.com
WHATSAPP_TIMEOUT=10s
